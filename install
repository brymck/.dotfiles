#!/bin/sh

THIS_DIR="$(cd "$(dirname "$0")" && pwd)"
EXIT_STATUS=0
FORCE=0

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

for arg in "$@"; do
    case "$arg" in
        --force|-f)
            FORCE=1
            ;;
    esac
done

checkmark() {
    printf "${GREEN}✓${NC}"
}

cross() {
    printf "${RED}✗${NC}"
}

warning() {
    printf "${YELLOW}!${NC}"
}

create_symlink() {
    target="$1"
    src="$2"
    target_path="$HOME/$target"
    src_path="$THIS_DIR/$src"
    removed_old=0

    # Check if it's already a symlink
    if [ -L "$target_path" ]; then
        current_link="$(readlink "$target_path")"
        if [ "$current_link" = "$src_path" ]; then
            # Correct symlink already exists
            printf "  "
            checkmark
            printf " %s\n" "$target"
            return 0
        else
            # Wrong symlink - handle based on force flag
            if [ "$FORCE" -eq 1 ]; then
                rm "$target_path" 2>/dev/null
                if [ $? -ne 0 ]; then
                    printf "  "
                    cross
                    printf " %s (failed to remove old symlink)\n" "$target"
                    EXIT_STATUS=1
                    return 1
                fi
                removed_old=1
            else
                printf "  "
                cross
                printf " %s (points to: %s, expected: %s)\n" "$target" "$current_link" "$src_path"
                EXIT_STATUS=1
                return 1
            fi
        fi
    fi

    # Check if a file or directory exists (not a symlink)
    if [ -e "$target_path" ]; then
        if [ "$FORCE" -eq 1 ]; then
            if [ -d "$target_path" ]; then
                rmdir "$target_path" 2>/dev/null
                if [ $? -ne 0 ]; then
                    rm -rf "$target_path" 2>/dev/null
                fi
            else
                rm "$target_path" 2>/dev/null
            fi
            if [ $? -ne 0 ]; then
                printf "  "
                cross
                printf " %s (failed to remove existing file/directory)\n" "$target"
                EXIT_STATUS=1
                return 1
            fi
            removed_old=1
        else
            printf "  "
            cross
            printf " %s (exists and is not a symlink)\n" "$target"
            EXIT_STATUS=1
            return 1
        fi
    fi

    target_dir="$(dirname "$target_path")"
    if [ ! -d "$target_dir" ]; then
        mkdir -p "$target_dir" 2>/dev/null
        if [ $? -ne 0 ]; then
            printf "  "
            cross
            printf " %s (failed to create parent directory)\n" "$target"
            EXIT_STATUS=1
            return 1
        fi
    fi

    ln -s "$src_path" "$target_path" 2>/dev/null
    if [ $? -eq 0 ]; then
        printf "  "
        if [ "$removed_old" -eq 1 ]; then
            warning
            printf " %s (removed old and recreated)\n" "$target"
        else
            checkmark
            printf " %s\n" "$target"
        fi
        return 0
    else
        printf "  "
        cross
        printf " %s (failed to create symlink)\n" "$target"
        EXIT_STATUS=1
        return 1
    fi
}

echo "Creating symlinks..."

create_symlink ".config/fish/config.fish" ".config/fish/config.fish"
create_symlink ".config/ghostty" ".config/ghostty"
create_symlink ".config/tmux" ".config/tmux"
create_symlink ".local/scripts" ".local/scripts"
create_symlink ".zsh_profile" ".zsh_profile"
create_symlink ".zshrc" ".zshrc"

exit $EXIT_STATUS
